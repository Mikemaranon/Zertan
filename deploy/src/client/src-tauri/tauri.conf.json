{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zertan Client",
  "version": "0.1.0",
  "identifier": "com.zertan.client",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "pattern": {
        "use": "brownfield"
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "Zertan Client",
        "width": 1120,
        "height": 860,
        "minWidth": 960,
        "minHeight": 720,
        "center": true,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "dmg"],
    "category": "Education",
    "shortDescription": "Dedicated client for connecting to Zertan servers.",
    "longDescription": "Native Tauri client for Zertan with local server selection and a dedicated remote workspace window.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
